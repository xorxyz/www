extends /templates/layouts/default.pug

block content
  section.bg-purple.white.pv3
    .container.blog-post
      article.tl
        a.white.underline.link(href="/game") Game
        span   /  
        span #{ post.data.title }
  section.blog-post
    .container
      article
        header
          h2 #{ post.data.title }

        content
          | !{ post.content }

        footer.mt4.pt2.pb4

          ul.tags
            for tag in post.data.tags
              li
                a(href="#") #{ tag }